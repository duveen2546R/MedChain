MEDCHAIN_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MEDCHAIN_SECRET_KEY=replace-with-at-least-32-random-characters
MEDCHAIN_ACCESS_TOKEN_MINUTES=120
MEDCHAIN_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority
MEDCHAIN_MONGODB_NAME=medchain
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=medchain-artifacts
MEDCHAIN_EVM_RPC_URL=
MEDCHAIN_EVM_CHAIN_ID=
MEDCHAIN_EVM_SIGNER_PRIVATE_KEY=
MEDCHAIN_CONSORTIUM_REGISTRY_ADDRESS=
MEDCHAIN_REPUTATION_REGISTRY_ADDRESS=
MEDCHAIN_TRAINING_LEDGER_ADDRESS=
MEDCHAIN_EVM_RECEIPT_TIMEOUT_SECONDS=120
MEDCHAIN_BOOTSTRAP_ADMIN_EMAIL=
MEDCHAIN_BOOTSTRAP_ADMIN_PASSWORD=
MEDCHAIN_BOOTSTRAP_ADMIN_NAME=Platform Administrator
